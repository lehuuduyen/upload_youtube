# Copy thành .env.production trên server rồi điền giá trị thật.
# docker-compose.prod.yml sẽ đọc file này cho cả backend lẫn Caddy.

# ── Domain ──────────────────────────────────────────────────────────────────
# Domain trỏ về server này (Caddy tự lấy SSL). Ví dụ: api.mydomain.com
API_DOMAIN=api.mydomain.com

# ── CORS: domain frontend trên Vercel ───────────────────────────────────────
# Ví dụ: https://myapp.vercel.app,https://app.mydomain.com
CORS_ORIGINS=https://myapp.vercel.app

# ── OAuth callbacks (phải thêm y hệt vào Google Cloud Console / TikTok) ─────
OAUTH_REDIRECT_URI=https://api.mydomain.com/api/channels/oauth/callback
TIKTOK_REDIRECT_URI=https://api.mydomain.com/api/tiktok/oauth/callback

# ── API keys ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=doi-secret-nay-thanh-chuoi-ngau-nhien
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh
AUTO_DELETE_AFTER_UPLOAD=true

# Playwright trong Docker luôn chạy headless
BROWSER_HEADLESS=true
