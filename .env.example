# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="YouTube Auto Uploader"
DEBUG=false
SECRET_KEY=your-very-secret-key-here

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default — no extra setup needed)
DATABASE_URL=sqlite:///./storage/app.db

# ─── YouTube OAuth2 ───────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → Enable "YouTube Data API v3"
# 3. Create OAuth 2.0 Client ID (Web app)
# 4. Add http://localhost:8000/api/channels/oauth/callback to Authorized redirect URIs
# 5. Download the client_secrets.json and place it in the project root
GOOGLE_CLIENT_SECRETS_FILE=./client_secrets.json
OAUTH_REDIRECT_URI=http://localhost:8000/api/channels/oauth/callback

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=America/Phoenix

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_CONCURRENT_DOWNLOADS=3
MAX_CONCURRENT_UPLOADS=2
MIN_UPLOAD_INTERVAL_MINUTES=30

# ─── Redis (optional — for Celery task queue) ─────────────────────────────────
# Only needed if you want to use Celery instead of background tasks
# REDIS_URL=redis://localhost:6379/0
