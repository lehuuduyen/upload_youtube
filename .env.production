# Production env cho backend chạy trên server này (5.78.145.172).
# Reverse proxy = system nginx (không dùng Caddy vì nginx đã giữ 80/443).

# ── Domain ──────────────────────────────────────────────────────────────────
API_DOMAIN=upload-youtube.naillib.com

# ── CORS: domain frontend (cập nhật khi deploy frontend, vd Vercel) ─────────
CORS_ORIGINS=https://upload-youtube.naillib.com,https://upload-youtube-seven.vercel.app

# ── Frontend URL: redirect về đây sau khi OAuth xong ────────────────────────
FRONTEND_URL=https://upload-youtube-seven.vercel.app

# ── OAuth callbacks (thêm y hệt vào Google Cloud Console / TikTok) ──────────
OAUTH_REDIRECT_URI=https://upload-youtube.naillib.com/api/channels/oauth/callback
TIKTOK_REDIRECT_URI=https://upload-youtube.naillib.com/api/tiktok/oauth/callback

